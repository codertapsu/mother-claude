{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mother Claude",
  "version": "0.2.0",
  "identifier": "dev.motherclaude.desktop",
  "build": {
    "frontendDist": "../dist/mother-claude/browser",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "(npm run sidecar:build || true) && npm run start",
    "beforeBuildCommand": "npm run sidecar:bundle && npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Mother Claude",
        "width": 1280,
        "height": 840,
        "minWidth": 480,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "publisher": "Mother Claude",
    "copyright": "© 2026 Mother Claude",
    "shortDescription": "Monitor and control every local Claude Code session.",
    "longDescription": "Mother Claude is a desktop dashboard that monitors and controls every local Claude Code session, agent, and service from one place, and serves the same dashboard over your LAN so you can drive Claude Code from your phone.",
    "createUpdaterArtifacts": true,
    "resources": {
      "../sidecar/dist": "sidecar/dist",
      "../sidecar/node_modules": "sidecar/node_modules",
      "../sidecar/package.json": "sidecar/package.json"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "./entitlements.plist",
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/codertapsu/mother-claude/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQzRkRCOTk0MkFDOENBQkMKUldTOHlzZ3FsTG45UThoVHBSM096cTBwZER5Qi9iTkozdDRvQk14NTN0N0NyclBXMXBaY055M0sK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
