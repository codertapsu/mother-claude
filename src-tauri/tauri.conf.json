{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mother Claude",
  "version": "0.1.0",
  "identifier": "dev.motherclaude.app",
  "build": {
    "frontendDist": "../dist/mother-claude/browser",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "(npm run sidecar:build || true) && npm run start",
    "beforeBuildCommand": "npm run sidecar:bundle && npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Mother Claude",
        "width": 1280,
        "height": 840,
        "minWidth": 480,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "resources": {
      "../sidecar/dist": "sidecar/dist",
      "../sidecar/node_modules": "sidecar/node_modules",
      "../sidecar/package.json": "sidecar/package.json"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
