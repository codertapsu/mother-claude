# Copy to `.env` for local overrides. Never commit a real token.
# All of these are optional; sane defaults are used when unset.

# Bind address / port for the embedded server.
MOTHER_CLAUDE_HOST=0.0.0.0
MOTHER_CLAUDE_PORT=6725

# Override the Claude config dir (defaults to ~/.claude).
# CLAUDE_CONFIG_DIR=/Users/you/.claude

# The API token is generated at runtime and printed to the console + shown in the
# desktop UI. It is also injected into hook env as MOTHER_CLAUDE_TOKEN. Do not set
# a real value here in committed files.
# MOTHER_CLAUDE_TOKEN=
