{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:6725/hooks/event",
            "headers": { "Authorization": "Bearer ${MOTHER_CLAUDE_TOKEN}" }
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:6725/hooks/event",
            "headers": { "Authorization": "Bearer ${MOTHER_CLAUDE_TOKEN}" }
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:6725/hooks/event",
            "headers": { "Authorization": "Bearer ${MOTHER_CLAUDE_TOKEN}" }
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:6725/hooks/event",
            "headers": { "Authorization": "Bearer ${MOTHER_CLAUDE_TOKEN}" }
          }
        ]
      }
    ]
  },
  "env": {
    "MOTHER_CLAUDE_TOKEN": "set-at-runtime"
  }
}
