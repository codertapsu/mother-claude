{
  "name": "mother-claude",
  "version": "0.1.0",
  "description": "One dashboard (desktop + phone) to monitor and control every local Claude Code session.",
  "private": true,
  "engines": {
    "node": ">=22.22.3"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:dev": "ng build --configuration development",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false --browsers=ChromeHeadless",
    "lint": "ng lint",
    "format": "prettier --write \"src/**/*.{ts,html,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss}\"",
    "sidecar:install": "npm --prefix sidecar install",
    "sidecar:build": "npm --prefix sidecar install && npm --prefix sidecar run build",
    "sidecar:bundle": "npm --prefix sidecar install && npm --prefix sidecar run build && npm --prefix sidecar prune --omit=dev",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@angular/common": "22.0.2",
    "@angular/compiler": "22.0.2",
    "@angular/core": "22.0.2",
    "@angular/forms": "22.0.2",
    "@angular/platform-browser": "22.0.2",
    "@angular/router": "22.0.2",
    "@tauri-apps/api": "2.11.1",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.16.2"
  },
  "devDependencies": {
    "@angular/build": "22.0.3",
    "@angular/cli": "22.0.3",
    "@angular/compiler-cli": "22.0.2",
    "@eslint/js": "10.0.1",
    "@tauri-apps/cli": "2.11.3",
    "@types/jasmine": "6.0.0",
    "angular-eslint": "22.0.0",
    "eslint": "10.5.0",
    "jasmine-core": "6.3.0",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.1",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.2.0",
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0"
  }
}
